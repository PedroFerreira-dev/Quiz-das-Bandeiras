<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/btnCorrect"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".china">

    <LinearLayout
        android:layout_width="409dp"
        android:layout_height="729dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2196F3"
            android:backgroundTint="#2196F3"
            android:text="Que país é este ?"
            android:textAlignment="center"
            android:textColor="#FAF9F9"
            android:textSize="34sp" />

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="match_parent"
            android:layout_height="276dp"
            android:scaleType="fitStart"
            app:srcCompat="@drawable/china" />

        <RadioGroup
            android:id="@+id/rdgOpcoes1"
            android:layout_width="match_parent"
            android:layout_height="match_parent" >

            <RadioButton
                android:id="@+id/rdbWrong1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Brasil" />

            <RadioButton
                android:id="@+id/rdbWrong2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jamaica" />

            <RadioButton
                android:id="@+id/rdbCorrect1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="China" />

            <RadioButton
                android:id="@+id/rdbWrong9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Italia" />

            <Button
                android:id="@+id/btnResponder1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#00B0FF"
                android:text="Responder" />
        </RadioGroup>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>